{
    "manifest_version": 3,
    "name": "InternTrack Clipper",
    "version": "1.0",
    "description": "Quickly save job applications from LinkedIn, Indeed, and Handshake to InternTrack.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "http://localhost:3000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Save to InternTrack"
    },
    "background": {
        "service_worker": "background.js"
    }
}